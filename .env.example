# Copy this file to `.env` and set a strong value before deploying.
#   cp .env.example .env
#
# ACCESS_PASSWORD is BOTH the login password AND the seed for the client-side
# E2EE key (PBKDF2 -> AES-GCM). The strength of all encryption equals the
# strength of this value, so use a long, unique passphrase in production.
# If left unset, the server generates a random one and prints it on startup.
ACCESS_PASSWORD=change-me-to-a-long-passphrase

# Set to 1 when running behind a reverse proxy (Caddy/Fly) so rate limiting
# uses the real client IP from X-Forwarded-For.
TRUST_PROXY=1

# ── Banco de dados (Postgres) ─────────────────────────────────────────────
# No docker compose local o DATABASE_URL já vem apontado pro serviço `db`.
# Em produção/Fly, defina como secret. Formato:
#   postgres://user:pass@host:5432/dbname
# DATABASE_URL=postgres://indio:indio@db:5432/indioflechudo
# DATABASE_SSL=1        # 1/true quando o Postgres exigir TLS (provedores externos)

# ── Bridge/MCP opcionais (respostas automáticas + modo agente via Claude) ──
# Rodam NO HOST e usam o `claude` CLI (sua assinatura, sem custo de API).
# Reusam o ACCESS_PASSWORD acima — este .env é a ÚNICA fonte de verdade.
# RELAY_URL aponta o bridge/mcp para o relay:
#   - local (docker):  http://localhost:3998   (default)
#   - produção (Fly):  https://SEU-APP.fly.dev
# RELAY_URL=http://localhost:3998
# Veja bridge/.env.example para overrides opcionais (CLAUDE_MODEL, etc.).
