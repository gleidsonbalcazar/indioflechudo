# Bridge config (caminho B via Claude Code CLI — SEM custo de API).
# O bridge roda NO HOST e reusa o `claude` já instalado/autenticado.
# Normalmente basta reusar o ../.env do relay (ACCESS_PASSWORD); estas vars
# são todas opcionais.

# Onde o relay responde.
#   - Local (docker compose, porta publicada no host): http://localhost:3998
#   - Produção (relay hospedado no Fly):               https://your-app.fly.dev
# RELAY_URL=http://localhost:3998

# Caminho do binário do claude, se não estiver no PATH do processo.
# CLAUDE_BIN=/Users/voce/.local/bin/claude

# Modelo (vazio = default do seu Claude Code). Ex.: opus, sonnet, ou id completo.
# CLAUDE_MODEL=sonnet

# Timeout por resposta do claude (ms).
# CLAUDE_TIMEOUT_MS=180000

# Diretrizes fixas anexadas ao system prompt (default: sem comentários no código
# + contexto C# legado). Defina para sobrescrever.
# BRIDGE_SYSTEM_PROMPT=...

# Responder mensagens que já existiam antes do bridge subir? (default: não)
# BRIDGE_ANSWER_BACKLOG=false

# Necessário (já está no ../.env do relay): ACCESS_PASSWORD
# O bridge usa a MESMA senha para login + derivar a chave E2EE.
